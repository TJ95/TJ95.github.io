---
// Live stats from tracker.gg embed
const trackerUrl = 'https://tracker.gg/valorant/profile/riot/exia%23002ssadkasjdk';
---

<article class="valorant-card">
  <iframe
    src={`${trackerUrl}/overview`}
    width="100%"
    height="600"
    frameborder="0"
    scrolling="no"
    title="Valorant Stats - exia#002"
    class="tracker-iframe"
  ></iframe>
</article>

<style>
  .valorant-card {
    max-width: 500px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
  }

  .tracker-iframe {
    display: block;
    width: 100%;
    min-height: 420px;
  }

  @media (max-width: 480px) {
    .tracker-iframe {
      min-height: 380px;
    }
  }
</style>
