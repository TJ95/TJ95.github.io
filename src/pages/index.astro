---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Section from '../components/Section.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ValorantCard from '../components/ValorantCard.astro';
import GallerySection from '../components/GallerySection.astro';
---

<Layout title="Tianjun Zhang | Portfolio" description="Personal portfolio showcasing experience, photography, and random things.">
  <Navigation />

  <!-- Hero / About Section -->
  <Section id="about">
    <div class="hero">
      <div class="hero-content-wrapper">
        <p class="hero-greeting">Hello, I'm</p>
        <h1 class="hero-title">TJ Zhang</h1>
        <p class="hero-subtitle">
          Full-stack developer who enjoys figuring out how things work.
        </p>
        <div class="hero-cta">
          <a href="https://www.linkedin.com/in/tianjun-tj-zhang-codes/" target="_blank" rel="noopener noreferrer" class="btn hero-btn" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="btn hero-btn">CV</a>
          <a href="https://github.com/TJ95" target="_blank" rel="noopener noreferrer" class="btn hero-btn" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
          </a>
          <a href="#gallery" class="btn btn-secondary hero-btn">Gallery</a>
          <a href="#misc" class="btn btn-secondary hero-btn">Misc.</a>
        </div>
      </div>

      <div class="hero-stats">
        <ScrollReveal animation="fade-up" delay={1}>
          <div class="stat">
            <span class="stat-number">5+</span>
            <span class="stat-label">Years Experience</span>
          </div>
        </ScrollReveal>
        <ScrollReveal animation="fade-up" delay={2}>
          <div class="stat">
            <span class="stat-number">8</span>
            <span class="stat-label">Hours Sleep</span>
            <span class="stat-subtext">...is the goal</span>
          </div>
        </ScrollReveal>
        <ScrollReveal animation="fade-up" delay={3}>
          <div class="stat">
            <span class="stat-number">∞</span>
            <span class="stat-label">Coffee Consumed</span>
          </div>
        </ScrollReveal>
      </div>

      <ScrollReveal animation="fade-up" delay={2}>
        <div class="tech-stack">
          <p class="tech-stack-label">Tech Stack</p>
          <div class="tech-tags">
            <span class="tech-tag">C++</span>
            <span class="tech-tag">Java</span>
            <span class="tech-tag">Node.js</span>
            <span class="tech-tag">Python</span>
            <span class="tech-tag">Rust</span>
            <span class="tech-tag">Android SDK</span>
            <span class="tech-tag">Git</span>
            <span class="tech-tag">PostgreSQL</span>
            <span class="tech-tag">ValKey</span>
            <span class="tech-tag">Docker</span>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </Section>

  <!-- Experiences Section -->
  <Section id="experiences">
    <ScrollReveal>
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">Experiences</h2>
        <p class="section-description">
          My professional journey and the places I've learned and grown
        </p>
      </div>
    </ScrollReveal>

    <div class="experiences-list">
      <ScrollReveal animation="fade-right">
        <div class="experience-item">
          <button class="experience-header" aria-expanded="false">
            <div class="experience-title-group">
          <h3 class="experience-title">Software Developer II – Improving Vancouver</h3>
              <span class="experience-date">July 2022 – July 2025 · Vancouver, BC, Canada</span>
            </div>
            <svg class="experience-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <hr class="experience-divider" />
          <div class="experience-content">
            <div class="experience-body">
              <p>Designed and developed high-performance database connectors enabling seamless integration across multiple data sources, reducing data retrieval latency and improving system interoperability for enterprise applications.</p>
              <ul class="experience-highlights">
                <li>Created and maintained an open-source, multi-language wrapper client for Redis/Amazon Valkey, streamlining database interactions and reducing integration time for developers</li>
                <li>Built high-performance Rust interfaces for Redis-like database services and unified client-facing APIs across 4+ programming languages, ensuring consistent developer experience</li>
                <li>Optimized data pipelines and workflows to achieve high availability and reliability in production data systems</li>
                <li>Authored comprehensive technical documentation for APIs, design patterns, and best practices, supporting both internal teams and external open-source contributors</li>
              </ul>
            </div>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal animation="fade-right" delay={2}>
        <div class="experience-item">
          <button class="experience-header" aria-expanded="false">
            <div class="experience-title-group">
              <h3 class="experience-title">Software Development Engineer – Huawei Technologies</h3>
              <span class="experience-date">April 2021 – June 2022 · Shanghai, China</span>
            </div>
            <svg class="experience-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <hr class="experience-divider" />
          <div class="experience-content">
            <div class="experience-body">
              <p>Developed an Android and HarmonyOS service distributing application client with features including service subscription, service exploring and promoted displays.</p>
              <ul class="experience-highlights">
                <li>Designed and implemented a SDK for application service messaging, integrated by third-party apps/services, enabling messaging & notifying through the main app as a messaging server, in multiple scenarios including order placement, parcel tracking, article subscription, etc.</li>
                <li>Designed and implemented a database system for the service distributing application that allows the fast retrieving and displaying of saved app data</li>
                <li>Integrated advertisement and app traffic monitoring feature into different modules of the application and achieved commercial exposure for third party advertisers</li>
                <li>Implemented dynamically controllable front-page display which improved exposure for promoted services by pushing up the display order of selected pages</li>
              </ul>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </Section>

  <!-- Gallery Section -->
  <GallerySection />

  <!-- Misc Section -->
  <Section id="misc">
    <ScrollReveal>
      <div class="section-header">
        <span class="section-number">04</span>
        <h2 class="section-title">Misc.</h2>
        <p class="section-description">
          When I'm not coding, I'm probably grinding ranked.
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal animation="fade-scale">
      <ValorantCard />
    </ScrollReveal>
  </Section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <p class="footer-text">
          Built with <span class="heart">♥</span> using Astro
        </p>
        <div class="footer-links">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="footer-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="footer-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
            </svg>
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="footer-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
        </div>
      </div>
      <p class="footer-copyright">
        © {new Date().getFullYear()} Your Name. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>

<style>
  /* Hero Section */
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .hero-content-wrapper {
    max-width: 600px;
  }

  .hero-greeting {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--accent);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .hero-title {
    margin-bottom: var(--space-md);
    line-height: 1.1;
    letter-spacing: 0.05em;
    font-weight: 700;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: nowrap;
  }

  .hero-btn {
    width: 70px;
    justify-content: center;
    padding: 0.5rem 0.75rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 500px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .stat-subtext {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-muted);
    font-style: italic;
    letter-spacing: 0.05em;
  }

  .tech-stack {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-color);
  }

  .tech-stack-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent-secondary);
    background-color: rgba(6, 182, 212, 0.1);
    padding: 0.375rem 0.75rem;
    border-radius: 4px;
    border: 1px solid rgba(6, 182, 212, 0.2);
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    background-color: var(--bg-secondary);
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }

  /* Section Header */
  .section-header {
    margin-bottom: var(--space-2xl);
    text-align: center;
  }

  .section-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .section-title {
    margin-bottom: var(--space-sm);
  }

  .section-description {
    max-width: 500px;
    margin: 0 auto;
    color: var(--text-secondary);
  }

  /* Experiences List */
  .experiences-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 1000px;
    margin: 0 auto;
  }

  .experience-item {
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .experience-item:hover {
    transform: translateX(8px);
  }

  .experience-header {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    text-align: left;
    color: var(--text-primary);
    transition: background-color 0.2s ease;
  }

  .experience-header:hover {
    background-color: rgba(255, 255, 255, 0.02);
  }

  .experience-title-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .experience-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .experience-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .experience-toggle-icon {
    color: var(--text-secondary);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .experience-header[aria-expanded="false"] .experience-toggle-icon {
    transform: rotate(-90deg);
  }

  .experience-content {
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    max-height: 500px;
    opacity: 1;
  }

  .experience-header[aria-expanded="false"] ~ .experience-content {
    max-height: 0;
    opacity: 0;
  }

  .experience-divider {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.4) 50%, transparent);
    margin: 0 var(--space-lg);
  }

  .experience-body {
    padding: var(--space-lg);
  }

  .experience-body p {
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
    line-height: 1.7;
  }

  .experience-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .experience-highlights li {
    color: var(--text-secondary);
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5rem;
    font-size: 0.9375rem;
  }

  .experience-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 6px;
    height: 6px;
    background-color: var(--text-primary);
    border-radius: 50%;
  }

  @media (max-width: 640px) {
    .experience-title {
      font-size: 1.1rem;
    }

    .experience-header {
      padding: var(--space-md);
    }

    .experience-body {
      padding: var(--space-md);
    }
  }

  /* Footer */
  .footer {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border-color);
    margin-top: var(--space-2xl);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .footer-text {
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .heart {
    color: #ff4655;
  }

  .footer-links {
    display: flex;
    gap: var(--space-md);
  }

  .footer-link {
    color: var(--text-secondary);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }

  .footer-copyright {
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-align: center;
  }

  @media (max-width: 640px) {
    .footer-content {
      flex-direction: column;
      gap: var(--space-md);
    }

    .hero-stats {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-sm);
    }

    .stat-number {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Experience accordion functionality
  document.querySelectorAll('.experience-header').forEach(header => {
    header.addEventListener('click', () => {
      const isExpanded = header.getAttribute('aria-expanded') === 'true';
      header.setAttribute('aria-expanded', !isExpanded);
    });
  });

</script>
