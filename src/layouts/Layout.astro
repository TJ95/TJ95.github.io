---
import HUDRing from '../components/HUDRing.astro';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Personal Website',
  description = 'A personal website showcasing projects, gallery, and more.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Styles are bundled via imports above -->

    <title>{title}</title>
  </head>
  <body>
    <HUDRing />
    <div class="content-layer">
      <slot />
    </div>

    <!-- Intersection Observer Fallback for scroll animations -->
    <script>
      // Only run if browser doesn't support animation-timeline
      if (!CSS.supports('animation-timeline', 'view()')) {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              // Optionally unobserve after animation
              // observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        // Observe all reveal elements
        document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => {
          observer.observe(el);
        });
      }
    </script>
  </body>
</html>

<style>
  body {
    position: relative;
    min-height: 100vh;
  }

  .content-layer {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    backdrop-filter: blur(30px) saturate(120%);
    -webkit-backdrop-filter: blur(30px) saturate(120%);
    background: linear-gradient(
      180deg,
      rgba(10, 10, 15, 0.15) 0%,
      rgba(10, 10, 15, 0.35) 50%,
      rgba(10, 10, 15, 0.55) 100%
    );
  }

  /* Fallback for browsers without backdrop-filter */
  @supports not (backdrop-filter: blur(60px)) {
    .content-layer {
      background: rgba(10, 10, 15, 0.85);
    }
  }
</style>
